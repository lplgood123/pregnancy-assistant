# 访问域名（建议先用 <公网IP>.sslip.io 做测试）
DOMAIN=YOUR_DOMAIN

# App 与后端校验用，同一份值要填到 Xcode 的 INFOPLIST_KEY_AI_BACKEND_TOKEN
AI_BACKEND_TOKEN=REPLACE_WITH_LONG_RANDOM_TOKEN

# 供应商密钥（后端统一读取 MINIMAX_API_KEY 变量名）
MINIMAX_API_KEY=REPLACE_WITH_PROVIDER_API_KEY

# 默认 Minimax（推荐）
MINIMAX_BASE_URL=https://api.minimax.io/v1
MINIMAX_MODEL=MiniMax-M2.5

# 如改用 Gemini OpenAI 兼容入口，可改成以下二行（不要和上面同时启用）
# MINIMAX_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
# MINIMAX_MODEL=gemini-2.5-flash

MINIMAX_CONNECT_TIMEOUT_SECONDS=8
MINIMAX_READ_TIMEOUT_SECONDS=35
MINIMAX_MAX_ATTEMPTS=2
MINIMAX_RETRY_BACKOFF_SECONDS=0.8
APP_TIMEZONE=Asia/Shanghai
